# ─────────────────────────────────────────────────────────────────────────────
# GoHighLevel (LeadConnector) integration — SERVER-SIDE ONLY
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in the values for THIS client / sub-account.
# Reusing the funnel for another client = a new .env with different values only.
# Nothing here is prefixed with VITE_, so Vite will NOT expose it to the browser.
# The API key lives only in the Netlify Functions runtime.
#
# On Netlify: set every variable below under
#   Site settings → Environment variables  (do NOT commit your real .env).
# Locally: `netlify dev` loads .env automatically.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core credentials ─────────────────────────────────────────────────────────
# GHL_API_KEY: a Private Integration token (Settings → Private Integrations) or a
#   Location API key with contacts/opportunities scopes.  ← ADD YOUR KEY
GHL_API_KEY=
# GHL_LOCATION_ID: the sub-account (location) ID.  ← ADD YOUR LOCATION ID
GHL_LOCATION_ID=
GHL_API_VERSION=2021-07-28
GHL_API_BASE_URL=https://services.leadconnectorhq.com

# ── Tags (plain tag names, created automatically in GHL if missing) ───────────
GHL_TAG_OPTIN=Bathroom Template Lead
GHL_TAG_QUIZ_STARTED=Quiz Started
GHL_TAG_QUIZ_COMPLETED=Quiz Completed
GHL_TAG_HIGH_INTENT=High Intent Lead

# ── Custom field IDs ─────────────────────────────────────────────────────────
# Paste the CUSTOM FIELD ID (not the name/key) for each. Find them in GHL under
# Settings → Custom Fields (open a field → the id is in the URL / API), or via
# GET /locations/{locationId}/customFields. Leave any blank to skip that field.
GHL_FIELD_TOWN=
GHL_FIELD_FUNNEL_SOURCE=
GHL_FIELD_QUIZ_RESPONSE_1=
GHL_FIELD_QUIZ_RESPONSE_2=
GHL_FIELD_QUIZ_RESPONSE_3=
GHL_FIELD_QUIZ_RESULT=
GHL_FIELD_SERVICE_INTEREST=
GHL_FIELD_LEAD_INTENT=

# ── Pipeline / stage (optional) ──────────────────────────────────────────────
# If BOTH are set, completing the quiz creates an opportunity. Leave blank to
# skip opportunity creation entirely.
GHL_PIPELINE_ID=
GHL_STAGE_ID=

# ── Optional overrides (sensible defaults applied if left blank) ──────────────
# Value stored in the funnel-source custom field on opt-in:
GHL_FUNNEL_SOURCE=Bathroom Website Template Funnel
# Extra tag added after the quiz (alongside Quiz Completed / High Intent / town):
GHL_TAG_SERVICE=Bathroom Remodel Lead
# Opportunity title = "{name} - {this suffix}":
GHL_OPPORTUNITY_NAME_SUFFIX=Bathroom Funnel Lead
